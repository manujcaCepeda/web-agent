{
  "_instructions": "Copy this file to /projects/{client_id}/config.json and fill in the values. Remove the _instructions field.",

  "client_id": "your-client-id",
  "template": "healthcare | agency | restaurant | ecommerce | consulting",
  "language": "en | es",
  "goal": "leads | sales | bookings | signups",

  "output": {
    "format": "html",
    "include_seo": true,
    "include_analytics": false
  },

  "features": {
    "whatsapp": true,
    "form": true,
    "animations": true,
    "lazy_loading": true,
    "schema_org": true
  },

  "analytics": {
    "ga4_id": "",
    "meta_pixel_id": "",
    "track_cta_clicks": true,
    "track_form_submit": true,
    "track_whatsapp_click": true
  },

  "localization": {
    "country": "US | EC | MX | CO | ES",
    "currency": "USD | EUR",
    "phone_format": "+1 (XXX) XXX-XXXX",
    "date_format": "MM/DD/YYYY | DD/MM/YYYY",
    "region": "",
    "trust_style": "us | latam | eu"
  },

  "deployment": {
    "env": "local",
    "base_path": "/projects/your-client-id"
  }
}
