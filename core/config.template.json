{
  "_instructions": "Copy this file to /projects/{client_id}/config.json and fill in the values.",

  "client_id": "your-client-id",
  "template": "healthcare",
  "language": "en",
  "goal": "leads",

  "output": {
    "format": "html",
    "include_seo": true,
    "include_analytics": false
  },

  "features": {
    "whatsapp": true,
    "form": true,
    "animations": true,
    "lazy_loading": true,
    "schema_org": true
  },

  "analytics": {
    "ga4_id": "",
    "meta_pixel_id": "",
    "track_cta_clicks": true,
    "track_form_submit": true,
    "track_whatsapp_click": true
  },

  "localization": {
    "country": "US",
    "currency": "USD",
    "phone_format": "+1 (XXX) XXX-XXXX",
    "date_format": "MM/DD/YYYY",
    "trust_style": "us"
  },

  "deployment": {
    "env": "local",
    "base_path": "/projects/your-client-id"
  }
}
