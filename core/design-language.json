{
  "_note": "Design Language System — defines visual identity per style_mode. The business-analyzer detects the mode. The frontend-dev applies it via CSS variables. Each mode makes sites look and feel distinct.",

  "style_modes": {

    "premium-care": {
      "description": "Warm, generous, human. For healthcare, senior care, wellness, family services.",
      "personality": ["trustworthy", "warm", "compassionate", "reassuring", "human"],
      "keywords_trigger": ["care", "senior", "family", "wellness", "home", "support", "compassion", "healing"],

      "colors": {
        "primary": "#2F7F79",
        "primary_dark": "#236059",
        "primary_light": "#3a9e97",
        "secondary": "#A7D7C5",
        "secondary_light": "#ceeae0",
        "accent": "#F59E0B",
        "background": "#FAFFFE",
        "surface": "#FFFFFF",
        "surface_alt": "#F0FAF7",
        "text_heading": "#111827",
        "text_body": "#4B5563",
        "text_muted": "#9CA3AF",
        "border": "rgba(167,215,197,0.4)"
      },

      "typography": {
        "heading_font": "'Inter', sans-serif",
        "body_font": "'Inter', sans-serif",
        "heading_weight": "800",
        "heading_tracking": "tight",
        "heading_line_height": "1.2",
        "body_line_height": "1.75",
        "accent_style": "color: var(--color-primary); font-weight: 800;"
      },

      "shape": {
        "card_radius": "rounded-2xl",
        "button_radius": "rounded-xl",
        "badge_radius": "rounded-full",
        "image_radius": "rounded-3xl"
      },

      "shadows": {
        "card": "shadow-md hover:shadow-xl",
        "hero_image": "shadow-2xl",
        "button": "0 8px 30px rgba(47,127,121,0.30)",
        "badge": "shadow-xl"
      },

      "spacing": {
        "section": "py-12 md:py-16",
        "section_spacious": "py-16 md:py-20",
        "card_inner": "p-6",
        "hero": "py-14 md:py-20"
      },

      "css_variables": ":root { --color-primary: #2F7F79; --color-primary-dark: #236059; --color-primary-light: #3a9e97; --color-secondary: #A7D7C5; --color-secondary-light: #ceeae0; --color-accent: #F59E0B; --color-bg: #FAFFFE; --radius-card: 1rem; --radius-button: 0.75rem; }",

      "hero_variant": "split-emotional",
      "hero_bg": "linear-gradient(135deg, #f0faf7 0%, #e6f7f0 100%)",

      "cta_style": "background: var(--color-primary); color: white; border-radius: var(--radius-button); padding: 1rem 2rem; font-weight: 700;",

      "card_style": "background: white; border-radius: var(--radius-card); border: 1px solid rgba(167,215,197,0.25); box-shadow: 0 2px 12px rgba(47,127,121,0.08);"
    },

